@model Project6RapidApi.Dtos.DashboardDtos.ResultDashboardDto


<div class="dashboard">
    <div class="sec-head" style="margin-bottom:32px">
        <div>
            <div class="sec-eyebrow">Anlık Veriler</div>
            <h2 class="sec-title">Seyahat <em>Paneli</em></h2>
        </div>
        <div style="display:flex;align-items:center;gap:8px;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#1a7a4a">
            <span style="width:8px;height:8px;background:#1a7a4a;border-radius:50%;display:inline-block;animation:lp 1.5s ease-in-out infinite"></span>
            Canlı Bağlantı Aktif
        </div>
    </div> 

    <div class="dashboard-split">
        @* --- DÖVİZ KURLARI --- *@
        <div class="dash-widget">
            <div class="dash-widget-tag">Döviz · TRY Bazlı</div>
            <div>
                @foreach (var item in Model.Currencies)
                {
                    <div class="curr-row">
                        <div class="curr-left">
                            <span class="curr-flag">@item.Symbol</span>
                            <span class="curr-code">@item.Code</span>
                        </div>
                        <div style="text-align:right">
                            <span class="curr-val">₺@item.Value.ToString("N2")</span>
                            <span class="curr-chg @(item.IsPositive ? "pos" : "neg")">
                                @(item.IsPositive ? "↑" : "↓") @item.Change
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* --- HAVA DURUMU --- *@
        <div class="dash-widget">
            <div class="dash-widget-tag">Hava Durumu · @Model.Weather.City</div>
            <div class="weather-big">
                @* Backend'den gelen Icon boşsa varsayılan güneş koyuyoruz *@
                <div class="weather-emoji">@(string.IsNullOrEmpty(Model.Weather.Icon) ? "☀️" : Model.Weather.Icon)</div>
                <div><div class="weather-num">@Model.Weather.Degree<sup>°C</sup></div></div>
            </div>
            <div class="weather-city-name">@Model.Weather.City, Türkiye</div>
            <div class="weather-desc-text">@Model.Weather.Description</div>
            <div class="weather-pills">
                <div class="weather-pill">💧 @Model.Weather.Humidity Nem</div>
                <div class="weather-pill">💨 @Model.Weather.WindSpeed</div>
                <div class="weather-pill">🌡 Hissedilen @Model.Weather.FeelsLike</div>
            </div>
        </div>

        @* --- AKARYAKIT (EURO -> TRY DÖNÜŞÜMLÜ) --- *@
        <div class="dash-widget">
            <div class="dash-widget-tag">Akaryakıt · Türkiye Fiyatları (TRY)</div>
            <div class="fuel-items">
                @if (Model.FuelPrices.Any())
                {
                    @foreach (var fuel in Model.FuelPrices)
                    {
                        <div>
                            <div class="fuel-top">
                                <span class="fuel-name">@fuel.FuelType</span>
                                <span><span class="fuel-val">₺@fuel.Price.ToString("N2")</span> <span class="fuel-unit">/lt</span></span>
                            </div>
                            <div class="fuel-track">
                                <div class="fuel-fill @fuel.ColorClass" style="width:@fuel.BarPercentage%"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted" style="font-size:12px; padding:10px;">Akaryakıt verisi yükleniyor...</div>
                }
            </div>
        </div>

        @* --- KRİPTO PARA --- *@
        <div class="dash-widget">
            <div class="dash-widget-tag">Kripto Borsası (Global)</div>
            <div class="crypto-items">
                @foreach (var crypto in Model.CryptoPrices)
                {
                    <div>
                        <div class="crypto-item">
                            @* CSS sınıfı için btc, eth gibi küçük harf kullanıyoruz *@
                            <div class="crypto-sym @crypto.Symbol.ToLower()">
                                @(crypto.Symbol.ToUpper() == "ETH" ? "Ξ" : (crypto.Symbol.ToUpper() == "BTC" ? "₿" : crypto.Symbol.ToUpper()))
                            </div>
                            <div class="crypto-mid">
                                <div class="crypto-name-t">@crypto.Name</div>
                                <div class="crypto-sym-t">@crypto.Code</div>
                            </div>
                            <div class="crypto-right">
                                <span class="crypto-price-t">@crypto.Price</span>
                                <span class="crypto-chg-t @(crypto.IsPositive ? "pos" : "neg")">
                                    @(crypto.IsPositive ? "↑" : "↓") @crypto.Change
                                </span>
                            </div>
                        </div>
                        <div class="mini-chart" id="@crypto.Symbol.ToLower()-chart"></div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* Küçük Animasyonlar İçin Inline Style (Eğer CSS'te yoksa) *@
<style>
    @@keyframes lp {
        0% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(1.2);
        }

        100% {
            opacity: 1;
            transform: scale(1);
        }
    }

    .pos {
        color: #1a7a4a !important;
        font-weight: bold;
    }

    .neg {
        color: #c62828 !important;
        font-weight: bold;
    }
</style>