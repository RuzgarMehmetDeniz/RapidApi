            city:"Paris", country:"Fransa",
            stars:5, rating:9.5, price:950,
            tag:"Tarihî",
            img:"https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=600&q=80",
            imgs:[
              "https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=1400&q=80",
              "https://images.unsplash.com/photo-1566073771259-6a8506099945?w=700&q=80",
              "https://images.unsplash.com/photo-1615460549969-36fa19521a4f?w=700&q=80"
            ],
            desc:"Place de la Concorde üzerinde, 1758'den bu yana Fransız zarafetinin sembolü. Marie Antoinette'in piyano çaldığı odalarda konaklama imkânı, Michelin yıldızlı Les Ambassadeurs restoranı ve Les Grandes Tables dünya standartlarında servis. Tarihin derinliğini çağdaş lüksle buluşturan bu saray, Paris'in en ikonik adresi.",
            amenities:["🏛️ Tarihî Bina","🍽️ Les Ambassadeurs","💆 Spa Chanel","🥐 Fransız Kahvaltısı","🎭 Concierge","🛁 Mermer Banyo"],
            lat:"48.8652° N", lng:"2.3215° E"
          },
          {
            id:3,
            name:"Capella Ubud",
            city:"Ubud", country:"Endonezya",
            stars:5, rating:9.8, price:1100,
            tag:"En Yüksek Puan",
            img:"https://images.unsplash.com/photo-1540541338287-41700207dee6?w=600&q=80",
            imgs:[
              "https://images.unsplash.com/photo-1540541338287-41700207dee6?w=1400&q=80",
              "https://images.unsplash.com/photo-1573843981267-be1999ff37cd?w=700&q=80",
              "https://images.unsplash.com/photo-1483683804023-6ccdb62f86ef?w=700&q=80"
