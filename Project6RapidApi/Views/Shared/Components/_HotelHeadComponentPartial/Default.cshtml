        /* TOAST */
        #toast {
            position: fixed;
            bottom: 32px;
            left: 32px;
            padding: 14px 24px;
            background: var(--ink);
            color: var(--white);
            border-left: 3px solid var(--red);
            font-size: 13px;
            font-weight: 500;
            z-index: 9999;
            transform: translateY(80px);
            opacity: 0;
            transition: transform .4s cubic-bezier(.34,1.56,.64,1), opacity .4s;
            letter-spacing: .5px;
        }

            #toast.show {
                transform: translateY(0);
                opacity: 1;
