@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">

    @await Component.InvokeAsync("_AtlasHeadComponentPartial")

<body>

    <!-- Custom cursor -->
    <div class="cursor" id="cursor"></div>
    <div class="cursor-ring" id="cursor-ring"></div>

    <!-- NAV -->
    @await Component.InvokeAsync("_AtlasNavbarComponentPartial")

    <!-- MAIN PAGE -->
    <div id="main-page">

        <!-- HERO -->
        @await Component.InvokeAsync("_AtlasHeroComponentPartial")

        <!-- MARQUEE -->
        <div class="marquee-strip">
            <div class="marquee-track" id="marquee-track">
                <!-- items will be doubled by JS -->
            </div>
        </div>

        <!-- SEARCH -->
        @await Component.InvokeAsync("_AtlasSearchComponentPartial")

        <!-- MAIN CONTENT -->
        <div class="page-main">

            <!-- LISTING -->
            <div class="sec-head">
                <div>
                    <div class="sec-eyebrow">Editör Seçimi</div>
                    <h2 class="sec-title" id="listing-title">Bu Sezon <em>Gitmeniz Gereken</em> Oteller</h2>
                </div>
                <div class="sec-meta" id="listing-meta">8 Destinasyon · Global Koleksiyon</div>
            </div>

            <div class="hotel-grid" id="hotel-grid">
                <!-- populated by JS -->
            </div>

            <!-- DASHBOARD -->
            @await Component.InvokeAsync("_AtlasBottomPanelComponentPartial")

        </div><!-- /page-main -->
        @await Component.InvokeAsync("_AtlasFooterComponentPartial")

    </div><!-- /main-page -->
    <!-- DETAIL OVERLAY -->
    <div id="detail-overlay">
        <div class="detail-header">
            <button class="detail-back" onclick="closeDetail()">← Listeye Dön</button>
            <a class="nav-logo" href="#" onclick="closeDetail()">ATL<span style="color:var(--red)">A</span>S</a>
            <button class="detail-book-btn" onclick="showToast('Rezervasyon sayfası açılıyor...')">Rezervasyon Yap</button>
        </div>

        <!-- PHOTO GALLERY -->
        <div class="photo-gallery" id="photo-gallery">
            <img class="gallery-main" id="gal-main" src="" alt="">
            <img id="gal-2" src="" alt="">
            <img id="gal-3" src="" alt="">
        </div>

        <!-- DETAIL BODY -->
        <div class="detail-body">
            <div class="detail-main">
                <div class="detail-cat" id="detail-cat">Premium · Şehir Oteli</div>
                <h1 class="detail-hotel-name" id="detail-hname">—</h1>

                <div class="detail-meta-row">
                    <div class="detail-loc" id="detail-hloc">📍 —</div>
                    <div class="detail-score-box">
                        <span class="num" id="detail-hscore">—</span>
                        <span class="lbl">Misafir<br>Puanı</span>
                    </div>
                    <div class="detail-stars-box" id="detail-hstars"></div>
                </div>

                <p class="detail-desc-text" id="detail-hdesc">—</p>

                <div class="detail-features-title">Öne Çıkan Özellikler</div>
                <div class="feat-grid" id="detail-feats"></div>

                <div class="detail-features-title">Giriş / Çıkış Saatleri</div>
                <div class="check-row">
                    <div class="check-box">
                        <div class="check-lbl">Check-in</div>
                        <div class="check-time-val">14:00</div>
                    </div>
                    <div class="check-box">
                        <div class="check-lbl">Check-out</div>
                        <div class="check-time-val">12:00</div>
                    </div>
                </div>

                <div class="detail-features-title">Konum</div>
                <div class="map-box">
                    <div class="map-pin-ico">📍</div>
                    <div class="map-coords-txt" id="detail-hcoords">—</div>
                </div>
            </div>

            <div class="detail-sidebar">
                <div class="booking-title">Rezervasyon Özeti</div>
                <div class="price-hero">
                    <div class="price-hero-amount" id="bk-price">$—</div>
                    <div class="price-hero-label">gecelik başlangıç fiyatı</div>
                </div>
                <div class="booking-inputs">
                    <div class="book-field">
                        <div class="book-field-label">Giriş Tarihi</div>
                        <div class="book-field-val" id="bk-in">—</div>
                    </div>
                    <div class="book-field">
                        <div class="book-field-label">Çıkış Tarihi</div>
                        <div class="book-field-val" id="bk-out">—</div>
                    </div>
                    <div class="book-field">
                        <div class="book-field-label">Misafir / Oda</div>
                        <div class="book-field-val" id="bk-guests">—</div>
                    </div>
                </div>
                <div class="total-row">
                    <div class="total-lbl">Toplam Tutar</div>
                    <div class="total-amt" id="bk-total">$—</div>
                </div>
                <button class="book-cta" onclick="showToast('Ödeme sayfasına yönlendiriliyorsunuz...')">Hemen Rezervasyon Yap</button>
                <div class="booking-notes">
                    <div class="booking-note">Ücretsiz iptal — 48 saat öncesine kadar</div>
                    <div class="booking-note">Fiyat garantisi — En iyi fiyat</div>
                    <div class="booking-note">Anlık onay — Hemen bildirim</div>
                </div>
            </div>
        </div>
    </div>

    <div id="toast"></div>

    <script>
        // ============================
        // DATA
        // ============================
        const HOTELS = [
          {
            id:1, featured:true,
            name:"Aman Tokyo",
            city:"Tokyo", country:"Japonya",
            stars:5, rating:9.6, price:820,
            tag:"Editör Seçimi",
            img:"https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=900&q=80",
            imgs:[
              "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=1400&q=80",
              "https://images.unsplash.com/photo-1611892440504-42a792e24d32?w=700&q=80",
              "https://images.unsplash.com/photo-1527838832700-5059252407fa?w=700&q=80"
            ],
            desc:"Tokyo'nun kalbi Otemachi'de, 33 katlı gökdelenin zirvesinde yer alan Aman Tokyo, Japon estetiği ve çağdaş lüksün kusursuz birleşimi. Washi kağıdı duvarlar, bambu tavanlar ve muhteşem Fuji Dağı manzarasıyla her detail özenle tasarlanmış. Aman Spa'nın 2.400 m² terapi alanı ve havuzu ile Tokyo'nun kozmopolit enerjisini kendinize göre hissedebilirsiniz.",
            amenities:["🗼 Fuji Manzarası","♨️ Aman Spa","🧘 Zen Bahçesi","🍣 Kaiseki Mutfak","🎌 Çay Seremonisi","🏙️ Şehir Merkezi"],
            lat:"35.6762° N", lng:"139.6503° E"
          },
          {
            id:2,
