        ];

        let currentSlide = 0;
        let currentHotel = null;
        let totalSlides = 0;

        // ============================
        // INIT
        // ============================
        window.onload = function () {
          // Set default dates
          const today = new Date();
          const nextWeek = new Date(today.getTime() + 7 * 24 * 60 * 60 * 1000);
          const nextTwoWeeks = new Date(today.getTime() + 14 * 24 * 60 * 60 * 1000);

          document.getElementById('checkin').value = formatDate(nextWeek);
          document.getElementById('checkout').value = formatDate(nextTwoWeeks);

          renderHotels(HOTELS);
          buildSparklines();
          animateWeather();
        };

        function formatDate(d) {
          return d.toISOString().split('T')[0];
        }

        function formatDateDisplay(str) {
          if (!str) return '—';
          const d = new Date(str + 'T00:00:00');
          return d.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
        }

        // ============================
        // HOTEL RENDERING
        // ============================
        function renderHotels(hotels) {
          const grid = document.getElementById('hotel-grid');

          if (!hotels.length) {
            grid.innerHTML = `
              <div class="empty-state">
                <div class="empty-icon">🏨</div>
                <div class="empty-title">Otel bulunamadı</div>
                <div class="empty-subtitle">Arama kriterlerinizi değiştirmeyi deneyin</div>
              </div>`;
            return;
          }

          grid.innerHTML = hotels.map((h, i) => `
            <div class="hotel-card fade-up" style="animation-delay:${0.05 * i}s" onclick="openDetail(${h.id})">
              <div class="hotel-img-wrap">
                <img class="hotel-img" src="${h.img}" alt="${h.name}" loading="lazy">
                <div class="hotel-badge">${h.badge}</div>
                <div class="hotel-fav" id="fav-${h.id}" onclick="toggleFav(event, ${h.id})">🤍</div>
              </div>
              <div class="hotel-body">
                <div class="hotel-location">📍 ${h.city}, ${h.country}</div>
                <div class="hotel-name">${h.name}</div>
                <div class="hotel-stars">
                  <div class="stars">${renderStars(h.stars)}</div>
                  <div class="hotel-rating"><strong>${h.rating}</strong> / 10</div>
                </div>
                <div class="hotel-amenities">
                  ${h.amenities.slice(0,3).map(a => `<span class="amenity-tag">${a}</span>`).join('')}
                </div>
                <div class="hotel-footer">
                  <div class="hotel-price">
                    <div class="hotel-price-label">Gecelik Başlangıç</div>
                    <div class="hotel-price-amount">$${h.price}</div>
                    <div class="hotel-price-night">KDV dahil</div>
                  </div>
                  <button class="btn-detail" onclick="openDetail(${h.id})">Detayları Gör →</button>
                </div>
              </div>
            </div>
          `).join('');
        }

        function renderStars(count) {
          return [1,2,3,4,5].map(i =>
            `<span class="star ${i <= count ? 'filled' : ''}">★</span>`
          ).join('');
        }

        function toggleFav(e, id) {
          e.stopPropagation();
          const el = document.getElementById('fav-' + id);
          const active = el.classList.toggle('active');
          el.textContent = active ? '❤️' : '🤍';
          showToast(active ? 'Favorilere eklendi' : 'Favorilerden çıkarıldı');
        }

        // ============================
        // SEARCH
        // ============================
        function performSearch() {
          const city = document.getElementById('search-city').value.trim();
          const title = document.getElementById('listing-title');
          const subtitle = document.getElementById('listing-subtitle');

          if (city) {
            title.innerHTML = `<span>${city}</span> Otelleri`;
            subtitle.textContent = `${city} için ${HOTELS.length} sonuç bulundu`;
          } else {
            title.innerHTML = `Öne Çıkan <span>Oteller</span>`;
            subtitle.textContent = 'Dünya genelinde seçilmiş premium destinasyonlar';
          }

          renderHotels(HOTELS);
          showToast(`${city || 'Tüm destinasyonlar'} için arama yapıldı`);

          document.querySelector('#listing-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // ============================
        // DETAIL PAGE
        // ============================
        function openDetail(id) {
          currentHotel = HOTELS.find(h => h.id === id);
          if (!currentHotel) return;

          // Populate data
          document.getElementById('detail-name').textContent = currentHotel.name;
          document.getElementById('detail-location').innerHTML = `📍 ${currentHotel.city}, ${currentHotel.country}`;
          document.getElementById('detail-desc').textContent = currentHotel.desc;
          document.getElementById('detail-score').textContent = currentHotel.rating;
          document.getElementById('detail-coords').textContent = `${currentHotel.lat}, ${currentHotel.lng}`;
          document.getElementById('booking-price').textContent = `$${currentHotel.price}`;

          // Stars
          document.getElementById('detail-stars').innerHTML = renderStars(currentHotel.stars);

          // Features
          document.getElementById('detail-features').innerHTML = currentHotel.amenities.map(a => `
            <div class="feature-item">
              <div class="feature-icon">${a.split(' ')[0]}</div>
              <div class="feature-text">${a.split(' ').slice(1).join(' ')}</div>
            </div>
          `).join('');

          // Booking info
          const checkin = document.getElementById('checkin').value;
          const checkout = document.getElementById('checkout').value;
          const guestsVal = document.getElementById('guests').value;
          const guestsText = document.getElementById('guests').options[document.getElementById('guests').selectedIndex].text;

          document.getElementById('booking-checkin').textContent = formatDateDisplay(checkin);
          document.getElementById('booking-checkout').textContent = formatDateDisplay(checkout);
          document.getElementById('booking-guests').textContent = guestsText;

          // Calculate nights
          if (checkin && checkout) {
            const d1 = new Date(checkin), d2 = new Date(checkout);
            const nights = Math.max(1, Math.round((d2 - d1) / (1000*60*60*24)));
            document.getElementById('booking-total').textContent = `$${(currentHotel.price * nights).toLocaleString()}`;
          }

          // Carousel
          buildCarousel(currentHotel.imgs);

          // Show
          document.getElementById('hotel-detail').style.display = 'block';
          document.getElementById('hotel-detail').scrollTop = 0;
          document.body.style.overflow = 'hidden';
        }

        function goBack() {
          document.getElementById('hotel-detail').style.display = 'none';
          document.body.style.overflow = '';
        }

        function goHome() {
          goBack();
        }

        // ============================
        // CAROUSEL
        // ============================
        function buildCarousel(imgs) {
          currentSlide = 0;
          totalSlides = imgs.length;

          const slides = document.getElementById('carousel-slides');
          const dots = document.getElementById('carousel-dots');

          slides.innerHTML = imgs.map(src => `
            <div class="carousel-slide">
              <img src="${src}" alt="Hotel image" loading="lazy">
            </div>
          `).join('');

          dots.innerHTML = imgs.map((_, i) => `
            <div class="carousel-dot ${i === 0 ? 'active' : ''}" onclick="goToSlide(${i})"></div>
          `).join('');

          updateCarousel();
        }

        function updateCarousel() {
          document.getElementById('carousel-slides').style.transform = `translateX(-${currentSlide * 100}%)`;
          document.querySelectorAll('.carousel-dot').forEach((d, i) => {
            d.classList.toggle('active', i === currentSlide);
          });
        }

        function nextSlide() {
          currentSlide = (currentSlide + 1) % totalSlides;
          updateCarousel();
        }

        function prevSlide() {
          currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
          updateCarousel();
        }

        function goToSlide(i) {
          currentSlide = i;
          updateCarousel();
        }

        // ============================
        // SPARKLINES
        // ============================
        function buildSparklines() {
          const buildSpark = (id, color, trend) => {
            const el = document.getElementById(id);
            if (!el) return;
            const bars = 20;
            let val = 50;
            let html = '';
            for (let i = 0; i < bars; i++) {
              val = Math.max(10, Math.min(90, val + (Math.random() - 0.5 + trend * 0.1) * 12));
              html += `<div class="spark-bar" style="height:${val}%;background:${color}44;"></div>`;
            }
            el.innerHTML = html;
          };

          buildSpark('btc-spark', '#f7931a', 1);
          buildSpark('eth-spark', '#627eea', -1);
        }

        // ============================
        // WEATHER
        // ============================
        function animateWeather() {
          const hour = new Date().getHours();
          const icon = document.getElementById('weather-icon');
          const desc = document.getElementById('weather-desc');

          if (hour >= 6 && hour < 10) { icon.textContent = '🌅'; desc.textContent = 'Sabah Güneşi'; }
          else if (hour >= 10 && hour < 17) { icon.textContent = '🌤'; desc.textContent = 'Parçalı Bulutlu'; }
          else if (hour >= 17 && hour < 20) { icon.textContent = '🌇'; desc.textContent = 'Akşam Sisi'; }
          else { icon.textContent = '🌙'; desc.textContent = 'Açık Gece'; }
        }

        // ============================
        // TOAST
        // ============================
        function showToast(msg) {
          const toast = document.getElementById('toast');
          document.getElementById('toast-msg').textContent = msg;
          toast.classList.add('show');
          setTimeout(() => toast.classList.remove('show'), 2800);
        }

        // keyboard nav
        document.addEventListener('keydown', e => {
          if (document.getElementById('hotel-detail').style.display === 'block') {
            if (e.key === 'ArrowRight') nextSlide();
            if (e.key === 'ArrowLeft') prevSlide();
            if (e.key === 'Escape') goBack();
          }
        });

        // Auto-advance carousel
        setInterval(() => {
          if (document.getElementById('hotel-detail').style.display === 'block' && totalSlides > 1) {
            nextSlide();
          }
        }, 5000);

        // Simulate live data updates
        setInterval(() => {
          const amounts = document.querySelectorAll('.currency-amount');
          amounts.forEach(el => {
            const num = parseFloat(el.textContent.replace('₺', ''));
            const jitter = (Math.random() - 0.5) * 0.04;
            el.textContent = '₺' + (num + jitter).toFixed(2);
          });
        }, 4000);
    </script>
</body>
</html>