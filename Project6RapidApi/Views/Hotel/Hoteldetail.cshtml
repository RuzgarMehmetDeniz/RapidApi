    <div id="toast"></div>

    <script>
        const PRICES = {1:820, 2:950, 3:1100, 4:2800, 5:3200, 6:1450, 7:680, 8:2600};
        const NAMES = {1:'Aman Tokyo',2:'Hôtel de Crillon',3:'Capella Ubud',4:'Singita Grumeti',5:'The Brando',6:"Badrutt's Palace",7:'One&amp;Only Royal Mirage',8:'Fogo Island Inn'};
        const LOCS = {1:'Tokyo, Japonya',2:'Paris, Fransa',3:'Ubud, Endonezya',4:'Serengeti, Tanzanya',5:'Tetiaroa, Fr. Polinezyası',6:'St. Moritz, İsviçre',7:'Dubai, BAE',8:'Fogo Island, Kanada'};
        const IMGS = {
          1:'https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=400&q=70',
          2:'https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=400&q=70',
          3:'https://images.unsplash.com/photo-1540541338287-41700207dee6?w=400&q=70',
          4:'https://images.unsplash.com/photo-1516426122078-c23e76319801?w=400&q=70',
          5:'https://images.unsplash.com/photo-1483683804023-6ccdb62f86ef?w=400&q=70',
          6:'https://images.unsplash.com/photo-1548013146-72479768bada?w=400&q=70',
          7:'https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=400&q=70',
          8:'https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=400&q=70'
        };

        // Read URL param
        const params = new URLSearchParams(window.location.search);
        const hotelId = parseInt(params.get('id')) || 1;

        // Show correct hotel page
        const page = document.getElementById('hotel-' + hotelId);
        if (page) {
          page.classList.add('active');
        } else {
          document.getElementById('hotel-1').classList.add('active');
        }

        // Breadcrumb
        const nameMap = {1:'Aman Tokyo',2:'Hôtel de Crillon',3:'Capella Ubud',4:'Singita Grumeti',5:'The Brando',6:"Badrutt's Palace",7:'One&Only Royal Mirage',8:'Fogo Island Inn'};
        document.getElementById('breadcrumb-name').textContent = nameMap[hotelId] || 'Otel Detayı';
        document.title = 'ATLAS — ' + (nameMap[hotelId] || 'Otel Detayı');

        // Set default dates
        const t = new Date();
        const addDays = (d,n) => { const x=new Date(d); x.setDate(x.getDate()+n); return x.toISOString().split('T')[0]; };
        const defIn = addDays(t, 7);
        const defOut = addDays(t, 14);

        for (let i = 1; i <= 8; i++) {
          const ci = document.getElementById('ci-' + i);
          const co = document.getElementById('co-' + i);
          if (ci) ci.value = defIn;
          if (co) co.value = defOut;
          recalc(i);

          if (ci) ci.addEventListener('change', () => recalc(i));
          if (co) co.addEventListener('change', () => recalc(i));
        }

        function recalc(id) {
          const ci = document.getElementById('ci-' + id);
          const co = document.getElementById('co-' + id);
          const tot = document.getElementById('total-' + id);
          const ni = document.getElementById('nights-' + id);
          if (!ci || !co || !tot) return;
          const price = PRICES[id] || 0;
          const nights = Math.max(1, Math.round((new Date(co.value) - new Date(ci.value)) / 86400000));
          if (tot) tot.textContent = '$' + (price * nights).toLocaleString();
          if (ni) ni.innerHTML = `<span>${nights}</span> gece · $${price.toLocaleString()}/gece`;
        }

        // Similar hotels (3 random others)
        const others = [1,2,3,4,5,6,7,8].filter(id => id !== hotelId).sort(() => Math.random()-.5).slice(0,3);
        document.getElementById('similar-grid').innerHTML = others.map(id => `
          <a class="similar-card" href="hotel-detail.html?id=${id}">
            <img src="${IMGS[id]}" alt="${NAMES[id]}">
            <div class="similar-card-body">
              <div class="similar-card-name">${NAMES[id]}</div>
              <div class="similar-card-loc">📍 ${LOCS[id]}</div>
              <div class="similar-card-price">$${PRICES[id].toLocaleString()} <span>/gece</span></div>
            </div>
          </a>`).join('');

        // Scroll to booking
        function scrollToBooking() {
          const sidebar = document.querySelector('#hotel-' + hotelId + ' .detail-sidebar');
          if (sidebar) sidebar.scrollIntoView({ behavior: 'smooth' });
        }

        // Toast
        function showToast(msg) {
          const t = document.getElementById('toast');
          t.textContent = msg;
          t.classList.add('show');
          setTimeout(() => t.classList.remove('show'), 2800);
        }

        // Cursor
        const cur = document.getElementById('cursor');
        const ring = document.getElementById('cursor-ring');
        let mx=0,my=0,rx=0,ry=0;
        document.addEventListener('mousemove', e => { mx=e.clientX; my=e.clientY; cur.style.left=mx+'px'; cur.style.top=my+'px'; });
        const animC = () => { rx+=(mx-rx)*.12; ry+=(my-ry)*.12; ring.style.left=rx+'px'; ring.style.top=ry+'px'; requestAnimationFrame(animC); };
        animC();
        document.querySelectorAll('a,button,.feat-item,.similar-card').forEach(el => {
          el.addEventListener('mouseenter', () => { cur.style.transform='translate(-50%,-50%) scale(2)'; ring.style.width='60px'; ring.style.height='60px'; ring.style.opacity='.3'; });
          el.addEventListener('mouseleave', () => { cur.style.transform='translate(-50%,-50%) scale(1)'; ring.style.width='36px'; ring.style.height='36px'; ring.style.opacity='.5'; });
        });
    </script>
