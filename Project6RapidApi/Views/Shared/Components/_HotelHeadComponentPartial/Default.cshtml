            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        .anim {
            opacity: 0;
            animation: slideUp .7s ease forwards;
        }

        .d1 {
            animation-delay: .1s
        }

        .d2 {
            animation-delay: .2s
        }

        .d3 {
            animation-delay: .3s
        }

        .d4 {
            animation-delay: .4s
        }

        .d5 {
            animation-delay: .5s
        }

