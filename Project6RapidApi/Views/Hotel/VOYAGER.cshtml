
@{
    Layout = null;
}
  
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Voyager — Global Otel Arama</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
          --navy: #080c14;
          --navy-2: #0d1422;
          --navy-3: #111c30;
          --navy-4: #162035;
          --gold: #c9a84c;
          --gold-light: #e8c96a;
          --electric: #4a9eff;
          --electric-dim: rgba(74,158,255,0.15);
          --glass: rgba(255,255,255,0.04);
          --glass-border: rgba(255,255,255,0.08);
          --text-primary: #f0ece4;
          --text-secondary: #8a9ab8;
          --text-muted: #4a5568;
          --success: #2ecc71;
          --warning: #f39c12;
          --danger: #e74c3c;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html { scroll-behavior: smooth; }

        body {
          font-family: 'DM Sans', sans-serif;
          background: var(--navy);
          color: var(--text-primary);
          min-height: 100vh;
          overflow-x: hidden;
        }

        /* TYPOGRAPHY */
        .serif { font-family: 'Cormorant Garamond', serif; }

        /* SCROLLBAR */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--navy); }
        ::-webkit-scrollbar-thumb { background: var(--navy-4); border-radius: 2px; }

        /* NAV */
        nav {
          position: fixed; top: 0; left: 0; right: 0; z-index: 100;
          display: flex; align-items: center; justify-content: space-between;
          padding: 20px 48px;
          background: linear-gradient(to bottom, rgba(8,12,20,0.95) 0%, transparent 100%);
          backdrop-filter: blur(12px);
          border-bottom: 1px solid rgba(255,255,255,0.04);
        }

        .nav-logo {
          font-family: 'Cormorant Garamond', serif;
          font-size: 26px;
          font-weight: 600;
          letter-spacing: 3px;
          color: var(--text-primary);
          text-decoration: none;
          display: flex; align-items: center; gap: 10px;
        }

        .nav-logo-dot {
          width: 6px; height: 6px;
          background: var(--gold);
          border-radius: 50%;
          animation: pulse 2s ease-in-out infinite;
        }

        @@keyframes pulse {
          0%, 100% { opacity: 1; transform: scale(1); }
          50% { opacity: 0.5; transform: scale(0.8); }
        }

        .nav-links {
          display: flex; align-items: center; gap: 36px;
          list-style: none;
        }

        .nav-links a {
          color: var(--text-secondary);
          text-decoration: none;
          font-size: 13px;
          font-weight: 400;
          letter-spacing: 1.5px;
          text-transform: uppercase;
          transition: color 0.3s;
        }

        .nav-links a:hover { color: var(--text-primary); }

        .nav-cta {
          padding: 10px 24px;
          background: transparent;
          border: 1px solid var(--gold);
          color: var(--gold) !important;
          border-radius: 2px;
          font-size: 12px !important;
          letter-spacing: 2px !important;
          text-transform: uppercase;
          transition: all 0.3s !important;
        }

        .nav-cta:hover {
          background: var(--gold) !important;
          color: var(--navy) !important;
        }

        /* HERO */
        .hero {
          position: relative;
          min-height: 100vh;
          display: flex; flex-direction: column;
          align-items: center; justify-content: center;
          overflow: hidden;
          padding: 0 24px;
        }

        .hero-bg {
          position: absolute; inset: 0;
          background:
            radial-gradient(ellipse 80% 60% at 50% 0%, rgba(74,158,255,0.08) 0%, transparent 60%),
            radial-gradient(ellipse 60% 40% at 80% 80%, rgba(201,168,76,0.06) 0%, transparent 60%),
            linear-gradient(180deg, #080c14 0%, #0a1020 50%, #080c14 100%);
        }

        .hero-grid {
          position: absolute; inset: 0;
          background-image:
            linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
          background-size: 80px 80px;
          mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 70%);
        }

        .hero-noise {
          position: absolute; inset: 0;
          opacity: 0.03;
          background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
          background-size: 200px 200px;
        }

        .hero-content {
          position: relative; z-index: 2;
          text-align: center;
          max-width: 900px;
        }

        .hero-eyebrow {
          display: inline-flex; align-items: center; gap: 12px;
          font-size: 11px; font-weight: 500;
          letter-spacing: 4px; text-transform: uppercase;
          color: var(--gold);
          margin-bottom: 28px;
        }

        .hero-eyebrow::before, .hero-eyebrow::after {
          content: '';
          width: 40px; height: 1px;
          background: linear-gradient(to right, transparent, var(--gold));
        }

        .hero-eyebrow::after { background: linear-gradient(to left, transparent, var(--gold)); }

        .hero-title {
          font-family: 'Cormorant Garamond', serif;
          font-size: clamp(52px, 8vw, 96px);
          font-weight: 300;
          line-height: 1.05;
          color: var(--text-primary);
          letter-spacing: -1px;
          margin-bottom: 20px;
        }

        .hero-title em {
          font-style: italic;
          color: var(--gold-light);
        }

        .hero-subtitle {
          font-size: 15px;
          color: var(--text-secondary);
          font-weight: 300;
          letter-spacing: 0.5px;
          margin-bottom: 56px;
          line-height: 1.8;
        }

        /* SEARCH BAR */
        .search-container {
          background: rgba(13,20,34,0.85);
          backdrop-filter: blur(24px);
          border: 1px solid var(--glass-border);
          border-radius: 6px;
          padding: 8px;
          display: flex; align-items: stretch; gap: 2px;
          max-width: 860px; width: 100%;
          margin: 0 auto;
          box-shadow: 0 40px 80px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.04);
        }

        .search-field {
          flex: 1;
          display: flex; flex-direction: column;
          padding: 12px 20px;
          border-right: 1px solid var(--glass-border);
          cursor: pointer;
          transition: background 0.2s;
          border-radius: 4px;
          position: relative;
        }

        .search-field:last-of-type { border-right: none; }
        .search-field:hover { background: rgba(255,255,255,0.04); }

        .search-field label {
          font-size: 10px;
          font-weight: 500;
          letter-spacing: 2px;
          text-transform: uppercase;
          color: var(--gold);
          margin-bottom: 6px;
        }

        .search-field input, .search-field select {
          background: transparent;
          border: none;
          outline: none;
          color: var(--text-primary);
          font-family: 'DM Sans', sans-serif;
          font-size: 14px;
          font-weight: 400;
          width: 100%;
        }

        .search-field input::placeholder { color: var(--text-muted); }

        .search-field select option { background: var(--navy-2); }

        .search-btn {
          display: flex; align-items: center; justify-content: center; gap: 10px;
          padding: 14px 32px;
          background: linear-gradient(135deg, var(--gold) 0%, #a07830 100%);
          border: none;
          border-radius: 4px;
          color: var(--navy);
          font-family: 'DM Sans', sans-serif;
          font-size: 13px;
          font-weight: 500;
          letter-spacing: 2px;
          text-transform: uppercase;
          cursor: pointer;
          transition: all 0.3s;
          white-space: nowrap;
          min-width: 120px;
        }

        .search-btn:hover {
          transform: translateY(-1px);
          box-shadow: 0 8px 24px rgba(201,168,76,0.3);
        }

        .search-btn:active { transform: translateY(0); }

        .hero-stats {
          display: flex; align-items: center; gap: 48px;
          margin-top: 48px;
          justify-content: center;
        }

        .hero-stat { text-align: center; }
        .hero-stat-num {
          font-family: 'Cormorant Garamond', serif;
          font-size: 36px;
          font-weight: 600;
          color: var(--text-primary);
          line-height: 1;
        }

        .hero-stat-label {
          font-size: 11px;
          letter-spacing: 2px;
          text-transform: uppercase;
          color: var(--text-muted);
          margin-top: 6px;
        }

        .hero-divider {
          width: 1px; height: 40px;
          background: var(--glass-border);
        }

        /* MAIN CONTENT */
        main {
          max-width: 1400px;
          margin: 0 auto;
          padding: 80px 48px;
        }

        /* SECTION HEADER */
        .section-header {
          display: flex; align-items: flex-end; justify-content: space-between;
          margin-bottom: 40px;
        }

        .section-title {
          font-family: 'Cormorant Garamond', serif;
          font-size: 42px;
          font-weight: 300;
          color: var(--text-primary);
          line-height: 1.1;
        }

        .section-title span { color: var(--gold); font-style: italic; }

        .section-subtitle {
          font-size: 13px;
          color: var(--text-muted);
          margin-top: 8px;
          letter-spacing: 0.5px;
        }

        .view-all {
          font-size: 12px;
          letter-spacing: 2px;
          text-transform: uppercase;
          color: var(--gold);
          text-decoration: none;
          display: flex; align-items: center; gap: 8px;
          transition: gap 0.3s;
          cursor: pointer;
          background: none; border: none;
        }

        .view-all:hover { gap: 14px; }

        /* HOTEL GRID */
        .hotel-grid {
          display: grid;
          grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
          gap: 24px;
        }

        .hotel-card {
          background: var(--navy-2);
          border: 1px solid var(--glass-border);
          border-radius: 8px;
          overflow: hidden;
          transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
          cursor: pointer;
          position: relative;
        }

        .hotel-card:hover {
          transform: translateY(-6px);
          box-shadow: 0 24px 60px rgba(0,0,0,0.4);
          border-color: rgba(201,168,76,0.2);
        }

        .hotel-img-wrap {
          position: relative;
          height: 220px;
          overflow: hidden;
        }

        .hotel-img {
          width: 100%; height: 100%;
          object-fit: cover;
          transition: transform 0.5s;
        }

        .hotel-card:hover .hotel-img { transform: scale(1.05); }

        .hotel-badge {
          position: absolute; top: 16px; left: 16px;
          padding: 6px 14px;
          background: rgba(8,12,20,0.85);
          backdrop-filter: blur(8px);
          border: 1px solid rgba(201,168,76,0.3);
          border-radius: 2px;
          font-size: 10px;
          font-weight: 500;
          letter-spacing: 2px;
          text-transform: uppercase;
          color: var(--gold);
        }

        .hotel-fav {
          position: absolute; top: 16px; right: 16px;
          width: 36px; height: 36px;
          background: rgba(8,12,20,0.7);
          backdrop-filter: blur(8px);
          border: 1px solid var(--glass-border);
          border-radius: 50%;
          display: flex; align-items: center; justify-content: center;
          cursor: pointer;
          transition: all 0.3s;
          font-size: 16px;
        }

        .hotel-fav:hover { border-color: rgba(201,168,76,0.5); }
        .hotel-fav.active { background: rgba(201,168,76,0.2); border-color: var(--gold); }

        .hotel-body { padding: 22px; }

        .hotel-location {
          font-size: 11px;
          letter-spacing: 2px;
          text-transform: uppercase;
          color: var(--electric);
          margin-bottom: 8px;
          display: flex; align-items: center; gap: 6px;
        }

        .hotel-name {
          font-family: 'Cormorant Garamond', serif;
          font-size: 22px;
          font-weight: 400;
          color: var(--text-primary);
          line-height: 1.2;
          margin-bottom: 12px;
        }

        .hotel-stars {
          display: flex; align-items: center; gap: 8px;
          margin-bottom: 16px;
        }

        .stars { display: flex; gap: 2px; }

        .star {
          font-size: 12px;
          color: var(--text-muted);
        }

        .star.filled { color: var(--gold); }

        .hotel-rating {
          font-size: 12px;
          color: var(--text-secondary);
        }

        .hotel-rating strong {
          color: var(--text-primary);
          font-weight: 500;
        }

        .hotel-amenities {
          display: flex; gap: 8px;
          margin-bottom: 20px;
          flex-wrap: wrap;
        }

        .amenity-tag {
          padding: 4px 12px;
          background: var(--glass);
          border: 1px solid var(--glass-border);
          border-radius: 2px;
          font-size: 11px;
          color: var(--text-secondary);
          letter-spacing: 0.5px;
        }

        .hotel-footer {
          display: flex; align-items: center; justify-content: space-between;
          padding-top: 18px;
          border-top: 1px solid var(--glass-border);
        }

        .hotel-price { }

        .hotel-price-label {
          font-size: 10px;
          letter-spacing: 1.5px;
          text-transform: uppercase;
          color: var(--text-muted);
          margin-bottom: 2px;
        }

        .hotel-price-amount {
          font-family: 'Cormorant Garamond', serif;
          font-size: 28px;
          font-weight: 600;
          color: var(--text-primary);
          line-height: 1;
        }

        .hotel-price-night {
          font-size: 11px;
          color: var(--text-muted);
        }

        .btn-detail {
          padding: 10px 22px;
          background: transparent;
          border: 1px solid var(--gold);
          border-radius: 3px;
          color: var(--gold);
          font-family: 'DM Sans', sans-serif;
          font-size: 12px;
          font-weight: 500;
          letter-spacing: 1.5px;
          text-transform: uppercase;
          cursor: pointer;
          transition: all 0.3s;
        }

        .btn-detail:hover {
          background: var(--gold);
          color: var(--navy);
        }

        /* DASHBOARD SECTION */
        .dashboard-section {
          margin-top: 100px;
          padding-top: 80px;
          border-top: 1px solid var(--glass-border);
        }

        .dashboard-grid {
          display: grid;
          grid-template-columns: repeat(4, 1fr);
          gap: 20px;
        }

        @@media (max-width: 1200px) {
          .dashboard-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @@media (max-width: 600px) {
          .dashboard-grid { grid-template-columns: 1fr; }
        }

        .widget {
          background: var(--navy-2);
          border: 1px solid var(--glass-border);
          border-radius: 8px;
          padding: 24px;
          position: relative;
          overflow: hidden;
          transition: border-color 0.3s;
        }

        .widget::before {
          content: '';
          position: absolute;
          top: 0; left: 0; right: 0;
          height: 2px;
          background: linear-gradient(90deg, transparent, var(--gold), transparent);
          opacity: 0;
          transition: opacity 0.3s;
        }

        .widget:hover { border-color: rgba(201,168,76,0.25); }
        .widget:hover::before { opacity: 1; }

        .widget-header {
          display: flex; align-items: center; justify-content: space-between;
          margin-bottom: 20px;
        }

        .widget-title {
          font-size: 10px;
          letter-spacing: 3px;
          text-transform: uppercase;
          color: var(--text-muted);
          font-weight: 500;
        }

        .widget-icon {
          width: 32px; height: 32px;
          border-radius: 4px;
          display: flex; align-items: center; justify-content: center;
          font-size: 16px;
        }

        .widget-icon.gold { background: rgba(201,168,76,0.1); }
        .widget-icon.blue { background: rgba(74,158,255,0.1); }
        .widget-icon.green { background: rgba(46,204,113,0.1); }
        .widget-icon.orange { background: rgba(243,156,18,0.1); }

        /* CURRENCY WIDGET */
        .currency-list { display: flex; flex-direction: column; gap: 14px; }

        .currency-row {
          display: flex; align-items: center; justify-content: space-between;
        }

        .currency-info { display: flex; align-items: center; gap: 12px; }

        .currency-flag {
          width: 28px; height: 20px;
          border-radius: 3px;
          font-size: 18px;
          line-height: 1;
          display: flex; align-items: center; justify-content: center;
        }

        .currency-code {
          font-size: 13px;
          font-weight: 500;
          color: var(--text-primary);
        }

        .currency-name {
          font-size: 11px;
          color: var(--text-muted);
        }

        .currency-rate {
          text-align: right;
        }

        .currency-amount {
          font-family: 'Cormorant Garamond', serif;
          font-size: 20px;
          font-weight: 600;
          color: var(--text-primary);
        }

        .currency-change {
          font-size: 11px;
          display: flex; align-items: center; gap: 3px;
          justify-content: flex-end;
        }

        .currency-change.up { color: var(--success); }
        .currency-change.down { color: var(--danger); }

        /* WEATHER WIDGET */
        .weather-main {
          display: flex; align-items: center; gap: 20px;
          margin-bottom: 20px;
        }

        .weather-icon { font-size: 56px; line-height: 1; }

        .weather-temp {
          font-family: 'Cormorant Garamond', serif;
          font-size: 52px;
          font-weight: 300;
          color: var(--text-primary);
          line-height: 1;
        }

        .weather-temp sup { font-size: 24px; color: var(--text-secondary); }

        .weather-desc {
          font-size: 13px;
          color: var(--text-secondary);
          margin-top: 4px;
        }

        .weather-city {
          font-size: 11px;
          letter-spacing: 2px;
          text-transform: uppercase;
          color: var(--gold);
          margin-top: 2px;
        }

        .weather-details {
          display: grid; grid-template-columns: repeat(3, 1fr);
          gap: 12px;
          padding-top: 16px;
          border-top: 1px solid var(--glass-border);
        }

        .weather-detail {
          text-align: center;
        }

        .weather-detail-val {
          font-size: 16px;
          font-weight: 500;
          color: var(--text-primary);
        }

        .weather-detail-label {
          font-size: 10px;
          letter-spacing: 1.5px;
          text-transform: uppercase;
          color: var(--text-muted);
          margin-top: 3px;
        }

        /* FUEL WIDGET */
        .fuel-list { display: flex; flex-direction: column; gap: 14px; }

        .fuel-row {
          display: flex; align-items: center; gap: 14px;
        }

        .fuel-type {
          display: flex; align-items: center; gap: 10px;
          flex: 1;
        }

        .fuel-dot {
          width: 8px; height: 8px; border-radius: 50%;
        }

        .fuel-label {
          font-size: 13px;
          color: var(--text-secondary);
        }

        .fuel-price-wrap { text-align: right; }

        .fuel-price {
          font-family: 'Cormorant Garamond', serif;
          font-size: 22px;
          font-weight: 600;
          color: var(--text-primary);
        }

        .fuel-unit { font-size: 11px; color: var(--text-muted); }

        .fuel-bar-wrap {
          width: 100%; height: 3px;
          background: var(--glass);
          border-radius: 2px;
          margin-top: 16px;
          overflow: hidden;
        }

        .fuel-bar { height: 100%; border-radius: 2px; transition: width 1s ease; }

        /* CRYPTO WIDGET */
        .crypto-list { display: flex; flex-direction: column; gap: 16px; }

        .crypto-row {
          display: flex; align-items: center; gap: 14px;
        }

        .crypto-icon {
          width: 36px; height: 36px;
          border-radius: 50%;
          display: flex; align-items: center; justify-content: center;
          font-size: 18px;
          font-weight: 700;
          flex-shrink: 0;
        }

        .crypto-icon.btc {
          background: linear-gradient(135deg, #f7931a, #ff6b00);
          color: white;
          font-family: 'Cormorant Garamond', serif;
          font-size: 16px;
        }

        .crypto-icon.eth {
          background: linear-gradient(135deg, #627eea, #3259d6);
          color: white;
          font-size: 20px;
        }

        .crypto-info { flex: 1; }

        .crypto-name {
          font-size: 14px;
          font-weight: 500;
          color: var(--text-primary);
        }

        .crypto-symbol {
          font-size: 11px;
          color: var(--text-muted);
        }

        .crypto-data { text-align: right; }

        .crypto-price {
          font-family: 'Cormorant Garamond', serif;
          font-size: 20px;
          font-weight: 600;
          color: var(--text-primary);
        }

        .crypto-change {
          font-size: 12px;
          font-weight: 500;
        }

        .up { color: var(--success); }
        .down { color: var(--danger); }

        /* SPARKLINE */
        .sparkline {
          display: flex; align-items: flex-end; gap: 2px;
          height: 32px;
          margin-top: 12px;
        }

        .spark-bar {
          flex: 1;
          background: var(--electric-dim);
          border-radius: 1px;
          transition: background 0.2s;
        }

        .spark-bar:hover { background: var(--electric); }

        /* LIVE DOT */
        .live-dot {
          display: inline-flex; align-items: center; gap: 6px;
          font-size: 10px;
          letter-spacing: 1.5px;
          text-transform: uppercase;
          color: var(--success);
        }

        .live-dot::before {
          content: '';
          width: 6px; height: 6px;
          background: var(--success);
          border-radius: 50%;
          animation: livePulse 1.5s ease-in-out infinite;
        }

        @@keyframes livePulse {
          0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(46,204,113,0.4); }
          50% { opacity: 0.7; box-shadow: 0 0 0 4px rgba(46,204,113,0); }
        }

        /* HOTEL DETAIL PAGE */
        #hotel-detail {
          display: none;
          position: fixed; inset: 0;
          z-index: 200;
          background: var(--navy);
          overflow-y: auto;
        }

        .detail-nav {
          position: sticky; top: 0; z-index: 10;
          display: flex; align-items: center; justify-content: space-between;
          padding: 20px 48px;
          background: rgba(8,12,20,0.9);
          backdrop-filter: blur(20px);
          border-bottom: 1px solid var(--glass-border);
        }

        .btn-back {
          display: flex; align-items: center; gap: 10px;
          background: none; border: none;
          color: var(--text-secondary);
          font-family: 'DM Sans', sans-serif;
          font-size: 13px;
          letter-spacing: 1.5px;
          text-transform: uppercase;
          cursor: pointer;
          transition: color 0.3s;
        }

        .btn-back:hover { color: var(--text-primary); }

        .btn-book {
          padding: 12px 36px;
          background: linear-gradient(135deg, var(--gold) 0%, #a07830 100%);
          border: none;
          border-radius: 3px;
          color: var(--navy);
          font-family: 'DM Sans', sans-serif;
          font-size: 13px;
          font-weight: 600;
          letter-spacing: 2px;
          text-transform: uppercase;
          cursor: pointer;
          transition: all 0.3s;
        }

        .btn-book:hover {
          box-shadow: 0 8px 24px rgba(201,168,76,0.3);
          transform: translateY(-1px);
        }

        .detail-content {
          max-width: 1200px;
          margin: 0 auto;
          padding: 60px 48px;
        }

        /* CAROUSEL */
        .carousel {
          position: relative;
          border-radius: 12px;
          overflow: hidden;
          height: 500px;
          margin-bottom: 60px;
        }

        .carousel-slides {
          display: flex;
          height: 100%;
          transition: transform 0.6s cubic-bezier(0.77, 0, 0.175, 1);
        }

        .carousel-slide {
          min-width: 100%;
          height: 100%;
          position: relative;
        }

        .carousel-slide img {
          width: 100%; height: 100%;
          object-fit: cover;
        }

        .carousel-overlay {
          position: absolute; inset: 0;
          background: linear-gradient(to bottom, transparent 50%, rgba(8,12,20,0.8) 100%);
        }

        .carousel-btn {
          position: absolute; top: 50%; transform: translateY(-50%);
          width: 48px; height: 48px;
          background: rgba(8,12,20,0.6);
          backdrop-filter: blur(8px);
          border: 1px solid var(--glass-border);
          border-radius: 50%;
          color: var(--text-primary);
          font-size: 20px;
          cursor: pointer;
          display: flex; align-items: center; justify-content: center;
          z-index: 5;
          transition: all 0.3s;
        }

        .carousel-btn:hover { background: rgba(201,168,76,0.2); border-color: var(--gold); }
        .carousel-btn.prev { left: 20px; }
        .carousel-btn.next { right: 20px; }

        .carousel-dots {
          position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
          display: flex; gap: 8px; z-index: 5;
        }

        .carousel-dot {
          width: 6px; height: 6px;
          border-radius: 50%;
          background: rgba(255,255,255,0.4);
          cursor: pointer;
          transition: all 0.3s;
        }

        .carousel-dot.active {
          width: 20px;
          border-radius: 3px;
          background: var(--gold);
        }

        /* DETAIL LAYOUT */
        .detail-layout {
          display: grid;
          grid-template-columns: 1fr 380px;
          gap: 40px;
        }

        .detail-main { }

        .detail-hotel-name {
          font-family: 'Cormorant Garamond', serif;
          font-size: 52px;
          font-weight: 300;
          color: var(--text-primary);
          line-height: 1.1;
          margin-bottom: 12px;
        }

        .detail-location {
          display: flex; align-items: center; gap: 8px;
          color: var(--electric);
          font-size: 13px;
          letter-spacing: 1.5px;
          text-transform: uppercase;
          margin-bottom: 20px;
        }

        .detail-rating-row {
          display: flex; align-items: center; gap: 20px;
          margin-bottom: 32px;
          padding-bottom: 32px;
          border-bottom: 1px solid var(--glass-border);
        }

        .detail-score {
          display: flex; align-items: center; gap: 10px;
        }

        .detail-score-num {
          font-family: 'Cormorant Garamond', serif;
          font-size: 36px;
          font-weight: 600;
          color: var(--text-primary);
          line-height: 1;
        }

        .detail-score-label {
          font-size: 11px;
          letter-spacing: 1.5px;
          text-transform: uppercase;
          color: var(--text-muted);
        }

        .detail-desc {
          font-size: 15px;
          line-height: 1.9;
          color: var(--text-secondary);
          margin-bottom: 40px;
        }

        /* FEATURES */
        .features-grid {
          display: grid; grid-template-columns: repeat(3, 1fr);
          gap: 16px;
          margin-bottom: 40px;
        }

        .feature-item {
          display: flex; align-items: center; gap: 12px;
          padding: 16px;
          background: var(--glass);
          border: 1px solid var(--glass-border);
          border-radius: 6px;
        }

        .feature-icon { font-size: 20px; }

        .feature-text {
          font-size: 13px;
          color: var(--text-secondary);
        }

        /* CHECK TIMES */
        .check-times {
          display: flex; gap: 20px;
          margin-bottom: 40px;
        }

        .check-card {
          flex: 1;
          padding: 20px;
          background: var(--glass);
          border: 1px solid var(--glass-border);
          border-radius: 6px;
          text-align: center;
        }

        .check-label {
          font-size: 10px;
          letter-spacing: 3px;
          text-transform: uppercase;
          color: var(--text-muted);
          margin-bottom: 8px;
        }

        .check-time {
          font-family: 'Cormorant Garamond', serif;
          font-size: 32px;
          font-weight: 400;
          color: var(--text-primary);
        }

        /* MAP */
        .map-placeholder {
          background: var(--navy-3);
          border: 1px solid var(--glass-border);
          border-radius: 8px;
          height: 220px;
          display: flex; flex-direction: column;
          align-items: center; justify-content: center;
          gap: 12px;
          position: relative;
          overflow: hidden;
        }

        .map-placeholder::before {
          content: '';
          position: absolute; inset: 0;
          background-image:
            linear-gradient(rgba(74,158,255,0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(74,158,255,0.04) 1px, transparent 1px);
          background-size: 40px 40px;
        }

        .map-pin {
          font-size: 40px;
          position: relative; z-index: 1;
          animation: mapBounce 2s ease-in-out infinite;
        }

        @@keyframes mapBounce {
          0%, 100% { transform: translateY(0); }
          50% { transform: translateY(-8px); }
        }

        .map-coords {
          font-size: 11px;
          letter-spacing: 1.5px;
          color: var(--electric);
          position: relative; z-index: 1;
        }

        /* DETAIL SIDEBAR */
        .detail-sidebar { }

        .booking-card {
          background: var(--navy-2);
          border: 1px solid var(--glass-border);
          border-radius: 10px;
          padding: 28px;
          position: sticky;
          top: 100px;
        }

        .booking-price {
          margin-bottom: 24px;
          padding-bottom: 24px;
          border-bottom: 1px solid var(--glass-border);
        }

        .booking-price-amount {
          font-family: 'Cormorant Garamond', serif;
          font-size: 48px;
          font-weight: 300;
          color: var(--text-primary);
          line-height: 1;
        }

        .booking-price-night { font-size: 14px; color: var(--text-muted); }

        .booking-fields { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }

        .booking-field {
          padding: 14px 16px;
          background: var(--glass);
          border: 1px solid var(--glass-border);
          border-radius: 4px;
        }

        .booking-field-label {
          font-size: 10px;
          letter-spacing: 2px;
          text-transform: uppercase;
          color: var(--gold);
          margin-bottom: 6px;
        }

        .booking-field-val {
          font-size: 14px;
          color: var(--text-primary);
        }

        .booking-total {
          display: flex; justify-content: space-between; align-items: center;
          padding: 16px 0;
          border-top: 1px solid var(--glass-border);
          margin-bottom: 20px;
        }

        .booking-total-label {
          font-size: 12px;
          letter-spacing: 1px;
          text-transform: uppercase;
          color: var(--text-secondary);
        }

        .booking-total-amount {
          font-family: 'Cormorant Garamond', serif;
          font-size: 28px;
          font-weight: 600;
          color: var(--gold);
        }

        .btn-book-full {
          width: 100%;
          padding: 16px;
          background: linear-gradient(135deg, var(--gold) 0%, #a07830 100%);
          border: none;
          border-radius: 4px;
          color: var(--navy);
          font-family: 'DM Sans', sans-serif;
          font-size: 13px;
          font-weight: 600;
          letter-spacing: 2px;
          text-transform: uppercase;
          cursor: pointer;
          transition: all 0.3s;
        }

        .btn-book-full:hover {
          box-shadow: 0 8px 24px rgba(201,168,76,0.3);
        }

        /* LOADING STATE */
        .loading-overlay {
          position: absolute; inset: 0;
          background: var(--navy);
          display: flex; align-items: center; justify-content: center;
          z-index: 10;
          border-radius: 8px;
        }

        .loading-spinner {
          width: 40px; height: 40px;
          border: 2px solid var(--glass-border);
          border-top-color: var(--gold);
          border-radius: 50%;
          animation: spin 0.8s linear infinite;
        }

        @@keyframes spin { to { transform: rotate(360deg); } }

        /* EMPTY STATE */
        .empty-state {
          text-align: center;
          padding: 80px 20px;
          grid-column: 1 / -1;
        }

        .empty-icon { font-size: 64px; margin-bottom: 24px; }

        .empty-title {
          font-family: 'Cormorant Garamond', serif;
          font-size: 32px;
          font-weight: 300;
          color: var(--text-secondary);
          margin-bottom: 12px;
        }

        .empty-subtitle {
          font-size: 14px;
          color: var(--text-muted);
        }

        /* FOOTER */
        footer {
          border-top: 1px solid var(--glass-border);
          padding: 48px;
          text-align: center;
        }

        .footer-logo {
          font-family: 'Cormorant Garamond', serif;
          font-size: 32px;
          font-weight: 300;
          letter-spacing: 6px;
          color: var(--text-muted);
          margin-bottom: 16px;
        }

        .footer-text {
          font-size: 12px;
          color: var(--text-muted);
          letter-spacing: 1px;
        }

        /* TOAST */
        .toast {
          position: fixed; bottom: 32px; right: 32px;
          padding: 14px 24px;
          background: var(--navy-2);
          border: 1px solid var(--gold);
          border-radius: 4px;
          color: var(--text-primary);
          font-size: 13px;
          z-index: 1000;
          transform: translateX(120%);
          transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
          display: flex; align-items: center; gap: 10px;
        }

        .toast.show { transform: translateX(0); }

        /* FADE IN */
        @@keyframes fadeUp {
          from { opacity: 0; transform: translateY(24px); }
          to { opacity: 1; transform: translateY(0); }
        }

        .fade-up {
          opacity: 0;
          animation: fadeUp 0.7s ease forwards;
        }

        .fade-up-1 { animation-delay: 0.1s; }
        .fade-up-2 { animation-delay: 0.2s; }
        .fade-up-3 { animation-delay: 0.3s; }
        .fade-up-4 { animation-delay: 0.4s; }

        /* RESPONSIVE */
        @@media (max-width: 1024px) {
          .detail-layout { grid-template-columns: 1fr; }
          .detail-sidebar { order: -1; }
          .booking-card { position: static; }
        }

        @@media (max-width: 768px) {
          nav { padding: 16px 24px; }
          .nav-links { display: none; }
          main { padding: 60px 24px; }
          .search-container { flex-direction: column; }
          .search-field { border-right: none; border-bottom: 1px solid var(--glass-border); }
          .search-field:last-of-type { border-bottom: none; }
          .hotel-grid { grid-template-columns: 1fr; }
          .features-grid { grid-template-columns: repeat(2, 1fr); }
          .detail-content { padding: 40px 24px; }
          .detail-nav { padding: 16px 24px; }
          .detail-hotel-name { font-size: 36px; }
          .carousel { height: 300px; }
        }
    </style>
</head>
