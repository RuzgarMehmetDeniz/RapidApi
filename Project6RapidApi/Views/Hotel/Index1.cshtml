@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AuraTravel | Modern Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0B0F1A;
        }

        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .hero-gradient {
            background: radial-gradient(circle at 50% 50%, #1e1b4b 0%, #0B0F1A 100%);
        }

        .glow {
            box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);
        }
    </style>
</head>
<body class="text-white selection:bg-indigo-500 selection:text-white">

    <nav class="fixed w-full z-50 glass py-4 px-8 flex justify-between items-center">
        <div class="text-2xl font-extrabold tracking-tighter text-indigo-400">AuraTravel.</div>
        <div class="hidden md:flex space-x-8 text-sm font-medium text-gray-300">
            <a href="#" class="hover:text-white transition">Hotels</a>
            <a href="#" class="hover:text-white transition">Dashboard</a>
            <a href="#" class="hover:text-white transition">Insights</a>
        </div>
        <button class="bg-indigo-600 hover:bg-indigo-500 px-5 py-2 rounded-full text-sm font-semibold transition glow">
            Get Started
        </button>
    </nav>

    <section class="hero-gradient pt-32 pb-20 px-6 text-center">
        <h1 class="text-5xl md:text-7xl font-extrabold mb-6 tracking-tight bg-clip-text text-transparent bg-gradient-to-b from-white to-gray-500">
            Discover Hotels & Travel <br> Insights in One Place
        </h1>
        <p class="text-gray-400 max-w-2xl mx-auto mb-12 text-lg">
            Search hotels worldwide and track real-time travel, currency, fuel, and crypto data in a premium dashboard.
        </p>

        <div class="max-w-5xl mx-auto glass p-2 rounded-3xl grid grid-cols-1 md:grid-cols-4 gap-2">
            <div class="p-4 text-left border-r border-white/10">
                <label class="block text-[10px] uppercase text-indigo-400 font-bold mb-1">Destination</label>
                <input type="text" value="Paris, France" class="bg-transparent outline-none w-full text-white placeholder-gray-500">
            </div>
            <div class="p-4 text-left border-r border-white/10">
                <label class="block text-[10px] uppercase text-indigo-400 font-bold mb-1">Check-in / Out</label>
                <input type="text" value="24 Apr - 30 Apr" class="bg-transparent outline-none w-full text-white">
            </div>
            <div class="p-4 text-left border-r border-white/10">
                <label class="block text-[10px] uppercase text-indigo-400 font-bold mb-1">Guests</label>
                <input type="text" value="2 Adults, 1 Room" class="bg-transparent outline-none w-full text-white">
            </div>
            <button class="bg-white text-black font-bold py-4 rounded-2xl hover:bg-indigo-400 transition hover:text-white">
                Search Hotels
            </button>
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-4 -mt-10">
        <div class="glass p-5 rounded-2xl">
            <h3 class="text-xs font-bold text-gray-500 uppercase mb-4 tracking-widest">Live Currency</h3>
            <div class="flex justify-between items-center mb-2">
                <span>USD/TRY</span>
                <span class="text-green-400 font-mono text-sm">32.42 ▲</span>
            </div>
            <div class="flex justify-between items-center text-xs text-gray-400">
                <span>EUR/USD</span>
                <span>1.0854</span>
            </div>
        </div>
        <div class="glass p-5 rounded-2xl">
            <h3 class="text-xs font-bold text-gray-500 uppercase mb-4 tracking-widest">Fuel Prices (TRY)</h3>
            <div class="flex justify-between items-center mb-2 font-mono">
                <span>Benzin</span>
                <span class="text-white">42.50</span>
            </div>
            <div class="w-full bg-white/5 h-1 rounded-full mb-1"><div class="bg-indigo-500 h-1 rounded-full w-[80%]"></div></div>
        </div>
        <div class="glass p-5 rounded-2xl">
            <h3 class="text-xs font-bold text-gray-500 uppercase mb-4 tracking-widest">Crypto Ticker</h3>
            <div class="flex justify-between items-center font-mono">
                <span>BTC</span>
                <span class="text-indigo-400 font-bold">$65,120</span>
            </div>
            <div class="text-[10px] text-green-500 mt-1">+2.45% Last 24h</div>
        </div>
        <div class="glass p-5 rounded-2xl flex items-center justify-between">
            <div>
                <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest">Istanbul</h3>
                <p class="text-2xl font-bold">24°C</p>
                <span class="text-xs text-gray-400">Partly Cloudy</span>
            </div>
            <div class="text-4xl">🌤️</div>
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-20">
        <div class="flex justify-between items-end mb-10">
            <div>
                <h2 class="text-3xl font-bold">Recommended for you</h2>
                <p class="text-gray-400 mt-2">Based on your recent search for Paris</p>
            </div>
            <button class="text-indigo-400 text-sm font-semibold hover:underline">View All</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <script>
                const hotels = [
                    { name: "L'Hôtel Chic", price: "$320", img: "https://images.unsplash.com/photo-1551882547-ff43c63efe81?auto=format&fit=crop&w=800&q=80", rating: "4.9" },
                    { name: "Grand Rivoli", price: "$210", img: "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=800&q=80", rating: "4.7" },
                    { name: "The Paris Vista", price: "$450", img: "https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?auto=format&fit=crop&w=800&q=80", rating: "4.8" },
                    { name: "Seine Boutique", price: "$180", img: "https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&w=800&q=80", rating: "4.6" }
                ];
                hotels.forEach(hotel => {
                    document.write(`
                        <div class="group cursor-pointer">
                            <div class="relative overflow-hidden rounded-3xl mb-4 h-64">
                                <img src="${hotel.img}" class="w-full h-full object-cover transform group-hover:scale-110 transition duration-700">
                                <div class="absolute top-4 right-4 glass px-3 py-1 rounded-full text-xs font-bold">⭐ ${hotel.rating}</div>
                            </div>
                            <h3 class="text-lg font-bold group-hover:text-indigo-400 transition">${hotel.name}</h3>
                            <p class="text-gray-500 text-sm mb-4">Paris, France • 5 mins from Louvre</p>
                            <div class="flex justify-between items-center">
                                <span class="text-xl font-extrabold text-white">${hotel.price}<span class="text-xs text-gray-500">/night</span></span>
                                <button class="p-2 bg-white/5 rounded-xl group-hover:bg-indigo-600 transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    `);
                });
            </script>
        </div>
    </section>

</body>
</html>