@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">

    @await Component.InvokeAsync("_HotelHeadComponentPartial")

<body>

    <div class="cursor" id="cursor"></div>
    <div class="cursor-ring" id="cursor-ring"></div>

    <!-- NAV -->
    @await Component.InvokeAsync("_HotelNavbarComponentPartial")

    <!-- HERO -->
    @await Component.InvokeAsync("_HotelHeroComponentPartial")

    <!-- MARQUEE -->
    @await Component.InvokeAsync("_HotelMarqueeComponentPartial")

    <!-- SEARCH -->
    <div class="search-section" id="search-section">
        <div class="search-label">Otel Arama</div>
        <div class="search-row">
            <div class="sf">
                <div class="sf-label">Destinasyon</div>
                <input type="text" id="search-city" placeholder="Şehir veya otel adı...">
            </div>
            <div class="sf">
                <div class="sf-label">Giriş</div>
                <input type="date" id="checkin" style="color-scheme:light;">
            </div>
            <div class="sf">
                <div class="sf-label">Çıkış</div>
                <input type="date" id="checkout" style="color-scheme:light;">
            </div>
            <div class="sf">
                <div class="sf-label">Misafir</div>
                <select id="guests">
                    <option>1 Misafir, 1 Oda</option>
                    <option selected>2 Misafir, 1 Oda</option>
                    <option>3 Misafir, 2 Oda</option>
                    <option>4 Misafir, 2 Oda</option>
                </select>
            </div>
            <button class="search-submit" onclick="doSearch()"><span>⌕</span> Ara</button>
        </div>
    </div>

    <!-- LISTING -->
    @await Component.InvokeAsync("_HotelListingComponentPartial", new { city = Context.Request.Query["city"].ToString() })

    <footer>
        <div class="footer-logo">ATL<span>A</span>S</div>
        <div class="footer-copy">© 2026 Atlas Luxury Travel. Tüm hakları saklıdır.</div>
    </footer>

    <div id="toast"></div>
    @await Component.InvokeAsync("_HotelScriptComponentPartial")

</body>
</html>