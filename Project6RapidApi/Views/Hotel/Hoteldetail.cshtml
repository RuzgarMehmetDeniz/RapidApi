@model Project6RapidApi.Dtos.HotelDtos.ResultHotelDto

@{
    Layout = null;
    // Controller'dan gelen tarihleri alıyoruz, yoksa bugünü kullanıyoruz
    string checkinValue = ViewBag.Checkin ?? DateTime.Now.ToString("yyyy-MM-dd");
    string checkoutValue = ViewBag.Checkout ?? DateTime.Now.AddDays(1).ToString("yyyy-MM-dd");
}

<!DOCTYPE html>
<html lang="tr">
    @await Component.InvokeAsync("_HotelDetailHeadComponentPartial")
<body>
    <div class="cursor" id="cursor"></div>
    <div class="cursor-ring" id="cursor-ring"></div>

    <nav>
        @* Geri dönerken arama parametrelerini koruyarak dönmek daha profesyonel olur *@
        <div class="nav-left"><a class="nav-back" href="javascript:history.back()">← Listeye Dön</a></div>
        <div class="nav-center"><a class="nav-logo" href="/">ATL<span>A</span>S</a></div>
        <div class="nav-right"><button class="nav-book-btn" onclick="scrollToBooking()">Rezervasyon Yap</button></div>
    </nav>

    <div class="breadcrumb">
        <a href="/">Atlas</a> <span class="breadcrumb-sep">/</span>
        <a href="/Hotel/Index">Oteller</a> <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">@Model.name</span>
    </div>

    <div class="hotel-page active">
        <div class="photo-gallery">
            @if (Model.photoUrls != null && Model.photoUrls.Length > 0)
            {
                <img class="gallery-main" src="@Model.photoUrls[0].Replace("square60", "square900")" alt="@Model.name">
                @for (int i = 1; i < Math.Min(Model.photoUrls.Length, 3); i++)
                {
                    <img src="@Model.photoUrls[i].Replace("square60", "square900")" alt="Görsel @(i + 1)">
                }
            }
        </div>

        <div class="detail-body">
            <div class="detail-main">
                <div class="detail-cat">5★ Premium · @(Model.reviewScoreWord ?? "Seçkin Otel")</div>
                <h1 class="detail-hotel-name">@Model.name</h1>
                <div class="detail-meta-row">
                    <div class="detail-loc">📍 @Model.wishlistName, @Model.countryCode</div>
                    <div class="detail-score-box"><span class="num">@Model.reviewScore.ToString("0.0")</span><span class="lbl">Misafir<br>Puanı</span></div>
                    <div class="detail-stars-box">
                        @for (int i = 0; i < 5; i++)
                        {
                            <span class="star on">★</span>
                        }
                    </div>
                </div>
                <p class="detail-desc-text">@(Model.accessibilityLabel ?? "Bu tesis konforlu ve kaliteli bir konaklama deneyimi sunmaktadır.") @Model.wishlistName bölgesinde unutulmaz bir deneyim.</p>

                @if (Model.FeaturedFeatures != null && Model.FeaturedFeatures.Any())
                {
                    <div class="detail-section-title">Öne Çıkan Özellikler</div>
                    <div class="feat-grid">
                        @foreach (var feature in Model.FeaturedFeatures)
                        {
                            <div class="feat-item"><div class="feat-ico">✨</div><div class="feat-txt">@feature</div></div>
                        }
                    </div>
                }

                <div class="detail-section-title">Konum</div>
                <div class="map-container" style="height:350px; border-radius:20px; overflow:hidden; position:relative; background:#222; border: 1px solid rgba(255,255,255,0.1);">
                    <iframe width="100%"
                            height="100%"
                            style="border:0; filter: grayscale(1) invert(0.9) contrast(1.2);"
                            loading="lazy"
                            allowfullscreen
                            src="https://maps.google.com/maps?q=@Model.latitude.ToString().Replace(",", "."),@Model.longitude.ToString().Replace(",", ".")&hl=tr&z=15&output=embed">
                    </iframe>

                    <div style="position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); z-index: 10;">
                        <a href="https://www.google.com/maps/dir/?api=1&destination=@Model.latitude.ToString().Replace(",", "."),@Model.longitude.ToString().Replace(",", ".")"
                           target="_blank"
                           class="nav-book-btn" style="text-decoration:none; display:inline-block">
                            Yol Tarifi Al →
                        </a>
                    </div>
                </div>
            </div>

            <div class="detail-sidebar" id="booking-section">
                <div class="booking-title">Rezervasyon Özeti</div>
                <div class="price-hero">
                    <div class="price-hero-amount">@Model.priceBreakdown.grossPrice.currency @Model.priceBreakdown.grossPrice.value.ToString("N0")</div>
                    <div class="price-hero-label">gecelik fiyat</div>
                </div>

                <div class="booking-inputs">
                    @* Buradaki value değerleri Controller'dan gelen dinamik değerlerdir *@
                    <div class="book-field"><label>Giriş Tarihi</label><input type="date" id="check-in-date" value="@checkinValue"></div>
                    <div class="book-field"><label>Çıkış Tarihi</label><input type="date" id="check-out-date" value="@checkoutValue"></div>
                </div>

                <div class="nights-info" id="nights-info"><span>1</span> gece konaklama</div>
                <div class="total-row"><div class="total-lbl">Toplam Tutar</div><div class="total-amt" id="total-amount">@Model.priceBreakdown.grossPrice.currency 0</div></div>
                <button class="book-cta" onclick="showToast('Ödeme sayfasına yönlendiriliyorsunuz...')">Hemen Rezervasyon Yap</button>
            </div>
        </div>
    </div>

    @await Component.InvokeAsync("_HotelSimilarListComponentPartial")

    <footer><div class="footer-logo">ATL<span>A</span>S</div></footer>
    <div id="toast"></div>

    <script>
        const pricePerNight = parseFloat("@Model.priceBreakdown.grossPrice.value".replace(',', '.'));
        const currencySymbol = "@Model.priceBreakdown.grossPrice.currency";

        const ciInput = document.getElementById('check-in-date');
        const coInput = document.getElementById('check-out-date');
        const nightsInfo = document.getElementById('nights-info');
        const totalAmount = document.getElementById('total-amount');

        function recalc() {
            const d1 = new Date(ciInput.value);
            const d2 = new Date(coInput.value);

            if (isNaN(d1) || isNaN(d2)) return;

            if (d2 <= d1) {
                d2.setDate(d1.getDate() + 1);
                coInput.value = d2.toISOString().split('T')[0];
            }

            const diff = Math.ceil(Math.abs(d2 - d1) / (1000 * 60 * 60 * 24));
            if (diff > 0) {
                const total = pricePerNight * diff;
                nightsInfo.innerHTML = `<span>${diff}</span> gece · ${currencySymbol} ${pricePerNight.toLocaleString('tr-TR')} /gece`;
                totalAmount.textContent = `${currencySymbol} ${total.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
            }
        }

        ciInput.addEventListener('change', recalc);
        coInput.addEventListener('change', recalc);
        recalc(); // Sayfa açıldığında otomatik hesapla

        function showToast(msg) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 2800);
        }

        function scrollToBooking() { document.getElementById('booking-section').scrollIntoView({ behavior: 'smooth' }); }

        // Custom Cursor Logic
        const cur = document.getElementById('cursor'), ring = document.getElementById('cursor-ring');
        let mx = 0, my = 0, rx = 0, ry = 0;
        document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; cur.style.left = mx + 'px'; cur.style.top = my + 'px'; });
        const animC = () => { rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12; ring.style.left = rx + 'px'; ring.style.top = ry + 'px'; requestAnimationFrame(animC); };
        animC();
    </script>
</body>
</html>