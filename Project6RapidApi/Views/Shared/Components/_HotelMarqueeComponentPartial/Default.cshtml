@model List<string>

<div class="marquee-strip">
    <div class="marquee-track">
        @* Listeyi 3 kez tekrarlatıyoruz ki ekran hiç boş kalmasın *@
        @for (int i = 0; i < 3; i++)
        {
            @foreach (var city in Model)
            {
                <span class="marquee-item">@city.ToUpper()<span class="marquee-dot"></span></span>
            }
        }
    </div>
</div>