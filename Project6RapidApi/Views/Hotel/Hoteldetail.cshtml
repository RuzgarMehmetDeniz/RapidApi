
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ATLAS — Otel Detayı</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream: #f5f0e8;
            --cream-2: #ede8df;
            --cream-3: #e8e0d4;
            --white: #faf8f4;
            --ink: #1a1510;
            --ink-2: #2d2620;
            --ink-light: #6b6057;
            --ink-muted: #a09588;
            --red: #c8352a;
            --red-dark: #9e2820;
            --sand: #d4c4a8;
            --sand-dark: #b5a488;
            --border: rgba(26,21,16,0.12);
            --border-strong: rgba(26,21,16,0.25);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Barlow', sans-serif;
            background: var(--cream);
            color: var(--ink);
            overflow-x: hidden;
            cursor: none;
        }

        /* CURSOR */
        .cursor {
            position: fixed;
            width: 10px;
            height: 10px;
            background: var(--red);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            transform: translate(-50%,-50%);
            transition: transform .15s, width .3s, height .3s;
        }

        .cursor-ring {
            position: fixed;
            width: 36px;
            height: 36px;
            border: 1.5px solid var(--red);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9998;
            transform: translate(-50%,-50%);
            opacity: .5;
            transition: transform .08s linear, width .3s, height .3s, opacity .3s;
        }

        ::-webkit-scrollbar {
            width: 3px;
        }

        ::-webkit-scrollbar-track {
            background: var(--cream-2);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--sand-dark);
        }

        /* NAV */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            background: var(--white);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: stretch;
            height: 64px;
        }

        .nav-left {
            display: flex;
            align-items: center;
            padding: 0 32px;
            border-right: 1px solid var(--border);
            gap: 24px;
        }

        .nav-back {
            display: flex;
            align-items: center;
            gap: 12px;
            background: none;
            border: none;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--ink-light);
            cursor: pointer;
            text-decoration: none;
            transition: color .2s;
        }

            .nav-back:hover {
                color: var(--red);
            }

        .nav-logo {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 8px;
            color: var(--ink);
            text-decoration: none;
        }

            .nav-logo span {
                color: var(--red);
            }

        .nav-center {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .nav-right {
            display: flex;
            align-items: center;
            padding: 0 32px;
            border-left: 1px solid var(--border);
        }

        .nav-book-btn {
            padding: 12px 36px;
            background: var(--red);
            color: var(--white);
            font-family: 'Barlow', sans-serif;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
            transition: background .3s;
        }

            .nav-book-btn:hover {
                background: var(--red-dark);
            }

        /* BREADCRUMB */
        .breadcrumb {
            margin-top: 64px;
            background: var(--white);
            border-bottom: 1px solid var(--border);
            padding: 14px 64px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 12px;
            color: var(--ink-muted);
        }

            .breadcrumb a {
                color: var(--ink-muted);
                text-decoration: none;
                transition: color .2s;
            }

                .breadcrumb a:hover {
                    color: var(--red);
                }

        .breadcrumb-sep {
            color: var(--border-strong);
        }

        .breadcrumb-current {
            color: var(--ink);
            font-weight: 500;
        }

        /* PHOTO GALLERY */
        .photo-gallery {
            display: grid;
            grid-template-columns: 2fr 1fr;
            grid-template-rows: 360px 240px;
            gap: 3px;
            background: var(--border-strong);
        }

            .photo-gallery img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
                transition: opacity .3s;
                cursor: zoom-in;
            }

                .photo-gallery img:hover {
                    opacity: .9;
                }

        .gallery-main {
            grid-row: span 2;
        }

        /* DETAIL BODY */
        .detail-body {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 0;
            background: var(--border);
            max-width: 100%;
        }

        .detail-main {
            padding: 56px 64px;
            background: var(--cream);
        }

        .detail-cat {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--red);
            margin-bottom: 16px;
        }

        .detail-hotel-name {
            font-family: 'Playfair Display', serif;
            font-size: clamp(36px, 4vw, 58px);
            font-weight: 900;
            line-height: 1.05;
            color: var(--ink);
            margin-bottom: 20px;
        }

        .detail-meta-row {
            display: flex;
            align-items: center;
            gap: 24px;
            margin-bottom: 36px;
            padding-bottom: 36px;
            border-bottom: 1px solid var(--border-strong);
            flex-wrap: wrap;
        }

        .detail-loc {
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--ink-light);
        }

        .detail-score-box {
            background: var(--red);
            color: var(--white);
            padding: 8px 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .detail-score-box .num {
                font-family: 'Playfair Display', serif;
                font-size: 24px;
                font-weight: 700;
            }

            .detail-score-box .lbl {
                font-size: 10px;
                letter-spacing: 1.5px;
                text-transform: uppercase;
                line-height: 1.3;
                opacity: .85;
            }

        .detail-stars-box {
            display: flex;
            gap: 3px;
        }

        .star {
            color: var(--sand-dark);
            font-size: 14px;
        }

            .star.on {
                color: var(--red);
            }

        .detail-desc-text {
            font-size: 15px;
            font-weight: 300;
            line-height: 1.9;
            color: var(--ink-light);
            margin-bottom: 40px;
        }

        .detail-section-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--ink);
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border);
        }

        .feat-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 40px;
        }

        .feat-item {
            padding: 16px;
            background: var(--white);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
            transition: border-color .2s;
        }

            .feat-item:hover {
                border-color: var(--red);
            }

        .feat-ico {
            font-size: 18px;
        }

        .feat-txt {
            font-size: 12px;
            font-weight: 500;
            color: var(--ink-light);
            letter-spacing: .3px;
        }

        .check-row {
            display: flex;
            gap: 16px;
            margin-bottom: 40px;
        }

        .check-box {
            flex: 1;
            padding: 20px 24px;
            background: var(--white);
            border: 1px solid var(--border);
            border-left: 3px solid var(--red);
        }

        .check-lbl {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--ink-muted);
            margin-bottom: 8px;
        }

        .check-time-val {
            font-family: 'Playfair Display', serif;
            font-size: 36px;
            font-weight: 700;
            color: var(--ink);
        }

        /* NEARBY HIGHLIGHTS */
        .nearby-row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }

        .nearby-tag {
            padding: 8px 16px;
            background: var(--white);
            border: 1px solid var(--border);
            font-size: 12px;
            font-weight: 500;
            color: var(--ink-light);
            transition: border-color .2s, color .2s;
        }

            .nearby-tag:hover {
                border-color: var(--red);
                color: var(--red);
            }

        /* MAP */
        .map-box {
            background: var(--ink-2);
            height: 220px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            position: relative;
            overflow: hidden;
        }

            .map-box::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
                background-size: 30px 30px;
            }

        .map-pin-ico {
            font-size: 36px;
            position: relative;
            z-index: 1;
            animation: pinBob 2s ease-in-out infinite;
        }
        @@keyframes pinBob {
            0%,100%

        {
            transform: translateY(0)
        }

        50% {
            transform: translateY(-6px)
        }

        }

        .map-coords-txt {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 13px;
            letter-spacing: 2px;
            color: var(--sand);
            position: relative;
            z-index: 1;
        }

        .map-directions {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 8px;
            padding: 8px 20px;
            background: var(--red);
            color: var(--white);
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            text-decoration: none;
            position: relative;
            z-index: 1;
            transition: background .3s;
        }

            .map-directions:hover {
                background: var(--red-dark);
            }

        /* SIDEBAR */
        .detail-sidebar {
            padding: 40px 36px;
            background: var(--white);
            border-left: 1px solid var(--border-strong);
        }

        .booking-title {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
        }

        .price-hero {
            margin-bottom: 28px;
        }

        .price-hero-amount {
            font-family: 'Playfair Display', serif;
            font-size: 52px;
            font-weight: 900;
            color: var(--ink);
            line-height: 1;
        }

        .price-hero-label {
            font-size: 13px;
            color: var(--ink-muted);
            margin-top: 4px;
        }

        .booking-inputs {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 20px;
        }

        .book-field {
            border: 1px solid var(--border);
            padding: 0;
            background: var(--cream);
            transition: border-color .2s;
        }

            .book-field:hover {
                border-color: var(--ink);
            }

            .book-field label {
                display: block;
                padding: 10px 16px 0;
                font-size: 9px;
                font-weight: 700;
                letter-spacing: 2.5px;
                text-transform: uppercase;
                color: var(--red);
            }

            .book-field input, .book-field select {
                display: block;
                width: 100%;
                padding: 4px 16px 10px;
                background: transparent;
                border: none;
                outline: none;
                font-family: 'Barlow', sans-serif;
                font-size: 14px;
                font-weight: 500;
                color: var(--ink);
            }

                .book-field select option {
                    background: white;
                }

        .nights-info {
            text-align: center;
            padding: 10px;
            font-size: 12px;
            color: var(--ink-muted);
            border: 1px dashed var(--border-strong);
            margin-bottom: 4px;
        }

            .nights-info span {
                font-family: 'Playfair Display', serif;
                font-size: 18px;
                font-weight: 700;
                color: var(--ink);
            }

        .total-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 0;
            border-top: 1.5px solid var(--ink);
            margin-bottom: 20px;
        }

        .total-lbl {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--ink-muted);
        }

        .total-amt {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 900;
            color: var(--red);
        }

        .book-cta {
            display: block;
            width: 100%;
            padding: 18px;
            background: var(--ink);
            color: var(--white);
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 4px;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
            text-align: center;
            transition: background .3s;
        }

            .book-cta:hover {
                background: var(--red);
            }

        .booking-notes {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
        }

        .booking-note {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 12px;
            color: var(--ink-muted);
            margin-bottom: 8px;
        }

            .booking-note::before {
                content: '✓';
                color: #1a7a4a;
                font-weight: 700;
                font-size: 13px;
                flex-shrink: 0;
            }

        /* SIMILAR HOTELS */
        .similar-section {
            padding: 64px 64px;
            background: var(--cream-2);
            border-top: 2px solid var(--ink);
        }

        .similar-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2px;
            background: var(--border);
            margin-top: 32px;
        }

        .similar-card {
            background: var(--white);
            text-decoration: none;
            display: block;
            transition: opacity .3s;
        }

            .similar-card:hover {
                opacity: .9;
            }

            .similar-card img {
                width: 100%;
                height: 200px;
                object-fit: cover;
                display: block;
                transition: transform .5s;
            }

            .similar-card:hover img {
                transform: scale(1.03);
            }

        .similar-card-body {
            padding: 20px 24px;
            border-top: 2px solid var(--ink);
        }

        .similar-card-name {
            font-family: 'Playfair Display', serif;
            font-size: 18px;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 6px;
        }

        .similar-card-loc {
            font-size: 12px;
            color: var(--ink-light);
            margin-bottom: 12px;
        }

        .similar-card-price {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--ink);
        }

            .similar-card-price span {
                font-family: 'Barlow', sans-serif;
                font-size: 12px;
                font-weight: 400;
                color: var(--ink-muted);
            }

        /* FOOTER */
        footer {
            background: var(--ink);
            padding: 48px 80px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-top: 3px solid var(--red);
        }

        .footer-logo {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 10px;
            color: var(--cream);
        }

            .footer-logo span {
                color: var(--red);
            }

        .footer-copy {
            font-size: 12px;
            color: var(--sand-dark);
            letter-spacing: 1px;
        }

        /* TOAST */
        #toast {
            position: fixed;
            bottom: 32px;
            left: 32px;
            padding: 14px 24px;
            background: var(--ink);
            color: var(--white);
            border-left: 3px solid var(--red);
            font-size: 13px;
            font-weight: 500;
            z-index: 9999;
            transform: translateY(80px);
            opacity: 0;
            transition: transform .4s cubic-bezier(.34,1.56,.64,1), opacity .4s;
        }

            #toast.show {
                transform: translateY(0);
                opacity: 1;
            }

        /* HIDDEN — shown by JS based on id param */
        .hotel-page {
            display: none;
        }

            .hotel-page.active {
                display: block;
            }

        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(20px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }

        }

        .hotel-page.active .detail-main, .hotel-page.active .detail-sidebar {
            animation: fadeIn .6s ease forwards;
        }

        .hotel-page.active .photo-gallery {
            animation: fadeIn .4s ease forwards;
        }

        @@media (max-width:1100px) {
            .detail-body

        {
            grid-template-columns: 1fr;
        }

        .detail-sidebar {
            border-left: none;
            border-top: 1px solid var(--border-strong);
        }

        .photo-gallery {
            grid-template-rows: 300px 200px;
        }

        .similar-grid {
            grid-template-columns: 1fr 1fr;
        }

        }
        @@media (max-width:768px) {
            .nav-left

        {
            padding: 0 20px;
        }

        .breadcrumb {
            padding: 14px 20px;
        }

        .detail-main {
            padding: 36px 24px;
        }

        .detail-sidebar {
            padding: 28px 24px;
        }

        .feat-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .photo-gallery {
            grid-template-columns: 1fr;
            grid-template-rows: 280px;
        }

            .photo-gallery img:not(:first-child) {
                display: none;
            }

        .gallery-main {
            grid-row: span 1;
        }

        .similar-grid {
            grid-template-columns: 1fr;
        }

        footer {
            flex-direction: column;
            gap: 16px;
            text-align: center;
            padding: 32px 24px;
        }

        .check-row {
            flex-direction: column;
        }

        .similar-section {
            padding: 40px 20px;
        }

        }
    </style>
</head>
<body>

    <div class="cursor" id="cursor"></div>
    <div class="cursor-ring" id="cursor-ring"></div>

    <!-- NAV -->
    <nav>
        <div class="nav-left">
            <a class="nav-back" href="index.html">← Listeye Dön</a>
        </div>
        <div class="nav-center">
            <a class="nav-logo" href="index.html">ATL<span>A</span>S</a>
        </div>
        <div class="nav-right">
            <button class="nav-book-btn" onclick="scrollToBooking()">Rezervasyon Yap</button>
        </div>
    </nav>

    <!-- BREADCRUMB -->
    <div class="breadcrumb">
        <a href="index.html">Atlas</a>
        <span class="breadcrumb-sep">/</span>
        <a href="index.html#search-section">Oteller</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current" id="breadcrumb-name">Otel Detayı</span>
    </div>

    <!-- ==================== HOTEL PAGES ==================== -->
    <!-- HOTEL 1: Aman Tokyo -->
    <div class="hotel-page" id="hotel-1">
        <div class="photo-gallery">
            <img class="gallery-main" src="https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=1400&q=80" alt="Aman Tokyo ana görsel">
            <img src="https://images.unsplash.com/photo-1611892440504-42a792e24d32?w=700&q=80" alt="Aman Tokyo oda">
            <img src="https://images.unsplash.com/photo-1527838832700-5059252407fa?w=700&q=80" alt="Aman Tokyo spa">
        </div>
        <div class="detail-body">
            <div class="detail-main">
                <div class="detail-cat">5★ Premium · Editör Seçimi</div>
                <h1 class="detail-hotel-name">Aman Tokyo</h1>
                <div class="detail-meta-row">
                    <div class="detail-loc">📍 Tokyo, Japonya</div>
                    <div class="detail-score-box"><span class="num">9.6</span><span class="lbl">Misafir<br>Puanı</span></div>
                    <div class="detail-stars-box">
                        <span class="star on">★</span><span class="star on">★</span><span class="star on">★</span><span class="star on">★</span><span class="star on">★</span>
                    </div>
                </div>
                <p class="detail-desc-text">Tokyo'nun kalbi Otemachi'de, 33 katlı gökdelenin zirvesinde yer alan Aman Tokyo, Japon estetiği ve çağdaş lüksün kusursuz birleşimi. Washi kağıdı duvarlar, bambu tavanlar ve muhteşem Fuji Dağı manzarasıyla her detay özenle tasarlanmış. Aman Spa'nın 2.400 m² terapi alanı ve havuzu ile Tokyo'nun kozmopolit enerjisini kendinize göre hissedebilirsiniz.</p>

                <div class="detail-section-title">Öne Çıkan Özellikler</div>
                <div class="feat-grid">
                    <div class="feat-item"><div class="feat-ico">🗼</div><div class="feat-txt">Fuji Manzarası</div></div>
